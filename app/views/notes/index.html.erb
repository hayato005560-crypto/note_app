<p style="color: green"><%= notice %></p>

<% content_for :title, "Notes" %>

<h1>Notes</h1>

<div id="notes">
  <% @notes.each do |note| %>
    <%= render 'note', note: note %>
    <p>
      <%= link_to "Show this note", note_path(note) %>
    </p>
  <% end %>
</div>

<%= link_to "New note", new_note_path %>
